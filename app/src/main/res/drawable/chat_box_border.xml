<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 內部底色 -->
    <solid android:color="#FFFFFF" />

    <!-- 粗邊框 -->
    <stroke
        android:width="2dp"
        android:color="#888888" /> <!-- 深灰色 -->

    <!-- 圓角 -->
    <corners android:radius="8dp" />

    <!-- 內部內距（可選） -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp"/>
</shape>
